# App
SECRET_KEY=change-me-to-a-random-string
FRONTEND_URL=http://localhost:5173
# Additional CORS origins (comma-separated list)
ALLOWED_ORIGINS=https://brooksroley.github.io

# Database (defaults to SQLite)
# For Oracle ATP, use oracle+oracledb://...
# Example: oracle+oracledb://username:password@dsn?wallet_location=/path/to/wallet&wallet_password=pass
DATABASE_URL=sqlite+aiosqlite:///./rhj.db

# Path to Oracle Wallet directory (if needed)
TNS_ADMIN=./wallet

# Oracle Object Storage (set both to enable OCI storage)
OCI_NAMESPACE=
OCI_BUCKET=
OCI_REGION=us-sanjose-1

# AWS S3 (leave empty if using OCI or local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=redhot-photos
S3_REGION=us-east-1

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
